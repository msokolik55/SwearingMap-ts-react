{
	"name": "swearing-map",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"packageManager": "pnpm@11.13.0",
	"engines": {
		"node": ">=24 <25",
		"pnpm": ">=11.13 <12"
	},
	"scripts": {
		"prepare": "node .husky/install.mjs",
		"nx": "nx",
		"dev": "nx dev map",
		"build": "nx run-many -t build --parallel=2",
		"check:bundle-budget": "node scripts/check-bundle-budget.mjs",
		"preview": "nx preview map",
		"typecheck": "nx run-many -t typecheck --parallel=2 && tsc --noEmit -p tsconfig.e2e.json",
		"lint": "nx run-many -t lint --parallel=2 && eslint . --max-warnings=0",
		"lint:fix": "eslint . --fix",
		"format": "prettier . --write",
		"format:check": "prettier . --check",
		"test": "nx run-many -t test --parallel=2 && pnpm test:tooling",
		"test:tooling": "node --test scripts/*.test.mjs",
		"test:coverage": "nx test map --coverage",
		"test:e2e": "pnpm build && playwright test",
		"test:e2e:ci": "playwright test",
		"test:lighthouse": "pnpm build && lhci autorun",
		"test:lighthouse:ci": "lhci autorun",
		"container:build": "docker build --tag swearing-map:local .",
		"container:smoke": "node scripts/smoke-container.mjs",
		"fallow:audit": "fallow audit --base origin/main --gate new-only --threads 2",
		"fallow:ci": "node scripts/fallow-ci.mjs",
		"fallow:full": "node scripts/fallow-full.mjs",
		"verify:staged": "lint-staged",
		"verify:changed": "node scripts/verify-changed.mjs",
		"verify:push": "pnpm verify:changed",
		"verify:ci": "pnpm fallow:ci && pnpm check",
		"verify:full": "pnpm audit && pnpm check && pnpm test:e2e:ci && pnpm test:lighthouse:ci",
		"push:safe": "node scripts/safe-push.mjs",
		"test:watch": "nx test map --watch",
		"audit": "pnpm audit --audit-level high",
		"check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
	},
	"devDependencies": {
		"@commitlint/cli": "21.2.1",
		"@commitlint/config-conventional": "21.2.0",
		"@eslint/js": "^9.39.5",
		"@lhci/cli": "^0.15.1",
		"@nx/eslint": "23.1.0",
		"@nx/vite": "23.1.0",
		"@nx/vitest": "23.1.0",
		"@playwright/test": "^1.61.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/leaflet": "^1.9.0",
		"@types/node": "^24.13.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react-swc": "^4.3.1",
		"@vitest/coverage-v8": "^4.1.10",
		"eslint": "^9.39.5",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.4.26",
		"fallow": "3.7.1",
		"globals": "^16.5.0",
		"husky": "9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "17.0.8",
		"nx": "23.1.0",
		"prettier": "^3.9.5",
		"tslib": "2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.64.0",
		"vite": "^8.1.4",
		"vitest": "^4.1.10"
	}
}
