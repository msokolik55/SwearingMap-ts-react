{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"allowJs": true,
		"incremental": true,
		"jsx": "preserve",
		"plugins": [{ "name": "next" }]
	},
	"include": [
		"next-env.d.ts",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"**/*.ts",
		"**/*.tsx"
	],
	"exclude": ["node_modules", "out"]
}
