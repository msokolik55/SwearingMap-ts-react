{
	"name": "map",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"projectType": "application",
	"sourceRoot": "apps/map/src",
	"tags": ["scope:map", "type:application"],
	"targets": {
		"lint": {
			"executor": "nx:run-commands",
			"cache": true,
			"options": {
				"command": "eslint . --max-warnings=0",
				"cwd": "apps/map"
			}
		},
		"typecheck": {
			"executor": "nx:run-commands",
			"cache": true,
			"options": {
				"commands": [
					"tsc --noEmit -p apps/map/tsconfig.json",
					"tsc --noEmit -p apps/map/tsconfig.node.json"
				],
				"parallel": true
			}
		},
		"build": {
			"executor": "nx:run-commands",
			"dependsOn": ["typecheck", "vite-build"],
			"cache": true,
			"outputs": ["{projectRoot}/dist"],
			"options": {
				"command": "node scripts/check-bundle-budget.mjs"
			}
		}
	}
}
